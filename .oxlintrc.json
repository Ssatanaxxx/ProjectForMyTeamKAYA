    // "typescript/no-unused-vars": "off",
    // "no-console": "off",
    // "no-debugger": "off",
    // "no-var": "off",
    // "prefer-const": "off",
    // "oxc/missing-throw": "off",
    // "oxc/uninvoked-array-callback": "off",
    // "oxc/double-comparisons": "off"
  }
}
